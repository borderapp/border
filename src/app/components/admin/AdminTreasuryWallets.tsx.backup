import { useState, useEffect } from 'react';
import { supabase } from '@/lib/supabase';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '../ui/card';
import { Button } from '../ui/button';
import { Input } from '../ui/input';
import { Label } from '../ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '../ui/select';
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from '../ui/table';
import { Badge } from '../ui/badge';
import { Dialog, DialogContent, DialogDescription, DialogHeader, DialogTitle, DialogTrigger } from '../ui/dialog';
import { toast } from 'sonner';
import { Wallet, Plus, RefreshCw, ExternalLink, Loader2, Copy, Eye } from 'lucide-react';
import { Textarea } from '../ui/textarea';

interface TreasuryWallet {
  id: string;
  wallet_id: string;
  wallet_address: string;
  chain: string;
  chain_id?: number;
  currency?: string;
  status: string;
  description?: string;
  created_at: string;
  created_by?: string;
  metadata?: Record<string, any>;
}

// Get Supabase config from the client instance
const SUPABASE_URL = 'https://ulolufsmjdlramdtstrr.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVsb2x1ZnNtamRscmFtZHRzdHJyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njc0NDYyNTgsImV4cCI6MjA4MzAyMjI1OH0.GJaUnmGH6EhkKjDsmBts7ezUBgX13Wu9NKZx6PzUwBA';

export default function AdminTreasuryWallets() {
  const [wallets, setWallets] = useState<TreasuryWallet[]>([]);
  const [loading, setLoading] = useState(true);
  const [creating, setCreating] = useState(false);
  const [isCreateOpen, setIsCreateOpen] = useState(false);
  const [backendError, setBackendError] = useState<string | null>(null);
  const [authError, setAuthError] = useState(false);

  // Form state
  const [chain, setChain] = useState<string>('polygon');
  const [currency, setCurrency] = useState<string>('USDC');
  const [description, setDescription] = useState<string>('');

  useEffect(() => {
    // Only fetch if component is mounted
    let mounted = true;

    const loadWallets = async () => {
      if (mounted) {
        await fetchWallets();
      }
    };

    loadWallets();

    return () => {
      mounted = false;
    };
  }, []);

  const fetchWallets = async () => {
    try {
      setLoading(true);

      // Get the current session for authentication
      const { data: { session }, error: sessionError } = await supabase.auth.getSession();

      if (sessionError || !session) {
        console.error('❌ No active session - user needs to log in');
        setAuthError(true);
        setBackendError('Authentication required');
        setWallets([]);
        setLoading(false);
        return;
      }

      console.log('✅ User authenticated:', session.user.id);
      console.log('🔑 Session token (first 50 chars):', session.access_token.substring(0, 50));
      console.log('🔑 Token expiry:', new Date(session.expires_at! * 1000).toISOString());
      console.log('🕐 Current time:', new Date().toISOString());

      // Use supabase.functions.invoke() which automatically handles auth
      const { data, error } = await supabase.functions.invoke('server/openfort/wallets', {
        method: 'GET',
      });

      if (error) {
        console.error('❌ Error response:', error);
        console.error('❌ Error name:', error.name);
        console.error('❌ Error message:', error.message);
        console.error('❌ Error context:', (error as any).context);

        // Check for authentication error
        if (error.message?.includes('401') || error.message?.includes('Unauthorized')) {
          console.error('❌ Unauthorized - session may have expired');
          setAuthError(true);
          setBackendError('Authentication required - please log in again');
          setWallets([]);
          return;
        }

        // Check if it's a table not found error
        if (error.message?.includes('table not found')) {
          console.error('❌ Treasury wallets table does not exist. Run migration first.');
          setBackendError('Database table not found');
          setWallets([]);
          return;
        }
        throw new Error(error.message || 'Failed to fetch wallets');
      }

      setWallets(data.wallets || []);
      setBackendError(null);
      setAuthError(false);
      console.log('📋 Treasury wallets loaded:', data.wallets?.length);
    } catch (error: any) {
      console.error('Error fetching wallets:', error);
      // Only log to console on initial load, don't show toast
      console.error('💡 To fix: Deploy Edge Function with "supabase functions deploy server"');
      setBackendError('Cannot connect to backend');
      setWallets([]);
    } finally {
      setLoading(false);
    }
  };

  const createWallet = async () => {
    if (!chain) {
      toast.error('Please select a blockchain network');
      return;
    }

    try {
      setCreating(true);

      console.log('🏦 Creating treasury wallet:', { chain, currency, description });

      // Get the current session for authentication
      const { data: { session }, error: sessionError } = await supabase.auth.getSession();

      if (sessionError || !session) {
        console.error('❌ No active session - user needs to log in');
        toast.error('Authentication required', {
          description: 'Please log in to create treasury wallets',
          duration: 5000
        });
        return;
      }

      // Use supabase.functions.invoke() which automatically handles auth
      const { data, error } = await supabase.functions.invoke('server/openfort/wallets/create', {
        method: 'POST',
        body: {
          chain,
          currency: currency && currency !== 'NONE' ? currency : null,
          description: description || null,
        },
      });

      if (error) {
        console.error('❌ Create wallet failed:', error);
        console.error('❌ Error data:', data);

        // Extract detailed error information
        const errorMessage = data?.error || error.message || 'Failed to create wallet';
        const errorDetails = data?.details || '';
        const errorHint = data?.hint || '';

        throw new Error(`${errorMessage}${errorDetails ? ` - ${errorDetails}` : ''}${errorHint ? ` (${errorHint})` : ''}`);
      }

      toast.success('Treasury wallet created successfully!');
      console.log('✅ Wallet created:', data.wallet);

      // Reset form
      setChain('polygon');
      setCurrency('USDC');
      setDescription('');
      setIsCreateOpen(false);

      // Refresh wallets list
      await fetchWallets();
    } catch (error: any) {
      console.error('❌ Error creating wallet:', error);

      // Extract clean error message
      let errorTitle = 'Failed to create wallet';
      let errorDescription = error.message || 'Unknown error occurred';

      // Check for specific error types
      if (error.message?.includes('Openfort API key not configured')) {
        errorTitle = 'Openfort API Not Configured';
        errorDescription = 'Please set OPENFORT_API_KEY in Supabase Edge Function secrets';
      } else if (error.message?.includes('table not found') || error.message?.includes('treasury_wallets')) {
        errorTitle = 'Database Table Missing';
        errorDescription = 'Run the treasury_wallets migration in Supabase SQL Editor';
      } else if (error.message?.includes('Invalid response from Openfort')) {
        errorTitle = 'Openfort API Error';
        errorDescription = 'The Openfort API returned an invalid response. Check Edge Function logs.';
      } else if (error.name === 'TypeError' && error.message.includes('fetch')) {
        errorTitle = 'Cannot connect to backend';
        errorDescription = 'Edge Function may not be deployed. Run: supabase functions deploy server --no-verify-jwt';
      }

      toast.error(errorTitle, {
        description: errorDescription,
        duration: 7000
      });
    } finally {
      setCreating(false);
    }
  };

  const copyToClipboard = (text: string, label: string) => {
    navigator.clipboard.writeText(text);
    toast.success(`${label} copied to clipboard`);
  };

  const getChainExplorerUrl = (chain: string, address: string) => {
    const explorers: Record<string, string> = {
      polygon: 'https://polygonscan.com/address/',
      base: 'https://basescan.org/address/',
      ethereum: 'https://etherscan.io/address/',
    };
    return explorers[chain.toLowerCase()] + address;
  };

  const getChainName = (chain: string) => {
    const names: Record<string, string> = {
      polygon: 'Polygon',
      base: 'Base',
      ethereum: 'Ethereum',
    };
    return names[chain.toLowerCase()] || chain;
  };

  const getChainBadgeColor = (chain: string) => {
    const colors: Record<string, string> = {
      polygon: 'bg-purple-500/10 text-purple-600 border-purple-500/20',
      base: 'bg-blue-500/10 text-blue-600 border-blue-500/20',
      ethereum: 'bg-gray-500/10 text-gray-600 border-gray-500/20',
    };
    return colors[chain.toLowerCase()] || 'bg-gray-500/10 text-gray-600 border-gray-500/20';
  };

  const getStatusBadgeColor = (status: string) => {
    const colors: Record<string, string> = {
      ACTIVE: 'bg-green-500/10 text-green-600 border-green-500/20',
      INACTIVE: 'bg-gray-500/10 text-gray-600 border-gray-500/20',
      SUSPENDED: 'bg-red-500/10 text-red-600 border-red-500/20',
    };
    return colors[status] || 'bg-gray-500/10 text-gray-600 border-gray-500/20';
  };

  return (
    <div className="space-y-6">
      {/* Authentication Error Alert */}
      {authError && (
        <Card className="border-red-200 bg-red-50">
          <CardContent className="pt-6">
            <div className="flex items-start gap-3">
              <div className="shrink-0">
                <div className="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
                  <Wallet className="w-5 h-5 text-red-600" />
                </div>
              </div>
              <div className="flex-1">
                <h3 className="font-semibold text-red-900">Authentication Required</h3>
                <p className="text-sm text-red-700 mt-1">
                  You need to be logged in to access the Treasury Wallets admin panel.
                </p>
                <div className="mt-3">
                  <p className="text-sm font-medium text-red-900">Please log in to continue:</p>
                  <Button
                    onClick={() => window.location.href = '/'}
                    className="mt-2"
                    variant="outline"
                  >
                    Go to Login
                  </Button>
                </div>
              </div>
            </div>
          </CardContent>
        </Card>
      )}

      {/* Backend Error Alert */}
      {backendError && !authError && (
        <Card className="border-orange-200 bg-orange-50">
          <CardContent className="pt-6">
            <div className="flex items-start gap-3">
              <div className="shrink-0">
                <div className="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center">
                  <Wallet className="w-5 h-5 text-orange-600" />
                </div>
              </div>
              <div className="flex-1">
                <h3 className="font-semibold text-orange-900">Backend Service Not Available</h3>
                <p className="text-sm text-orange-700 mt-1">
                  {backendError === 'Edge Function not deployed' && 'The Edge Function needs to be deployed to use treasury wallets.'}
                  {backendError === 'Database table not found' && 'The database migration needs to be run to create the treasury_wallets table.'}
                  {backendError === 'Cannot connect to backend' && 'Cannot connect to the backend service. The Edge Function may not be deployed.'}
                  {backendError === 'Authentication required' && 'Please log in to access this admin panel.'}
                  {backendError === 'Authentication required - please log in again' && 'Your session has expired. Please log in again.'}
                  {!['Edge Function not deployed', 'Database table not found', 'Cannot connect to backend', 'Authentication required', 'Authentication required - please log in again'].includes(backendError) && backendError}
                </p>
                {!authError && (
                  <div className="mt-3 space-y-2">
                    <p className="text-sm font-medium text-orange-900">Quick fix:</p>
                    <code className="block text-xs bg-orange-100 px-3 py-2 rounded border border-orange-200 text-orange-900">
                      supabase functions deploy server
                    </code>
                    <p className="text-xs text-orange-600 mt-1">
                      See DEPLOY_EDGE_FUNCTION.md for complete setup instructions
                    </p>
                  </div>
                )}
              </div>
            </div>
          </CardContent>
        </Card>
      )}

      <div className="flex items-center justify-between">
        <div>
          <h2 className="text-2xl font-bold flex items-center gap-2">
            <Wallet className="w-6 h-6" />
            Treasury Wallets
          </h2>
          <p className="text-sm text-muted-foreground mt-1">
            Manage Openfort treasury wallets for stablecoin operations
          </p>
        </div>
        <div className="flex gap-2">
          <Button
            onClick={fetchWallets}
            variant="outline"
            disabled={loading}
          >
            <RefreshCw className={`w-4 h-4 mr-2 ${loading ? 'animate-spin' : ''}`} />
            Refresh
          </Button>
          <Dialog open={isCreateOpen} onOpenChange={setIsCreateOpen}>
            <DialogTrigger asChild>
              <Button>
                <Plus className="w-4 h-4 mr-2" />
                Create New Wallet
              </Button>
            </DialogTrigger>
            <DialogContent>
              <DialogHeader>
                <DialogTitle>Create Treasury Wallet</DialogTitle>
                <DialogDescription>
                  Create a new blockchain wallet via Openfort API for treasury operations.
                </DialogDescription>
              </DialogHeader>
              <div className="space-y-4 py-4">
                <div className="space-y-2">
                  <Label htmlFor="chain">Blockchain Network *</Label>
                  <Select value={chain} onValueChange={setChain}>
                    <SelectTrigger id="chain">
                      <SelectValue placeholder="Select chain" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="polygon">Polygon (137)</SelectItem>
                      <SelectItem value="base">Base (8453)</SelectItem>
                      <SelectItem value="ethereum">Ethereum (1)</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
                <div className="space-y-2">
                  <Label htmlFor="currency">Primary Currency (Optional)</Label>
                  <Select value={currency} onValueChange={setCurrency}>
                    <SelectTrigger id="currency">
                      <SelectValue placeholder="Select currency" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="USDC">USDC</SelectItem>
                      <SelectItem value="USDT">USDT</SelectItem>
                      <SelectItem value="DAI">DAI</SelectItem>
                      <SelectItem value="NONE">None</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
                <div className="space-y-2">
                  <Label htmlFor="description">Description (Optional)</Label>
                  <Textarea
                    id="description"
                    placeholder="e.g., Main treasury wallet for USDC operations"
                    value={description}
                    onChange={(e) => setDescription(e.target.value)}
                    rows={3}
                  />
                </div>
              </div>
              <div className="flex justify-end gap-2">
                <Button
                  variant="outline"
                  onClick={() => {
                    if (!creating) {
                      setIsCreateOpen(false);
                      // Reset form on cancel
                      setChain('polygon');
                      setCurrency('USDC');
                      setDescription('');
                    }
                  }}
                  disabled={creating}
                >
                  Cancel
                </Button>
                <Button onClick={createWallet} disabled={creating || !chain}>
                  {creating && <Loader2 className="w-4 h-4 mr-2 animate-spin" />}
                  {creating ? 'Creating...' : 'Create Wallet'}
                </Button>
              </div>
            </DialogContent>
          </Dialog>
        </div>
      </div>

      {/* Stats Cards */}
      <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
        <Card>
          <CardHeader className="pb-3">
            <CardDescription>Total Wallets</CardDescription>
            <CardTitle className="text-3xl">{wallets.length}</CardTitle>
          </CardHeader>
        </Card>
        <Card>
          <CardHeader className="pb-3">
            <CardDescription>Active</CardDescription>
            <CardTitle className="text-3xl">
              {wallets.filter(w => w.status === 'ACTIVE').length}
            </CardTitle>
          </CardHeader>
        </Card>
        <Card>
          <CardHeader className="pb-3">
            <CardDescription>Polygon</CardDescription>
            <CardTitle className="text-3xl">
              {wallets.filter(w => w.chain.toLowerCase() === 'polygon').length}
            </CardTitle>
          </CardHeader>
        </Card>
        <Card>
          <CardHeader className="pb-3">
            <CardDescription>Base</CardDescription>
            <CardTitle className="text-3xl">
              {wallets.filter(w => w.chain.toLowerCase() === 'base').length}
            </CardTitle>
          </CardHeader>
        </Card>
      </div>

      {/* Wallets Table */}
      <Card>
        <CardHeader>
          <CardTitle>All Treasury Wallets</CardTitle>
          <CardDescription>
            View and manage all programmatically created treasury wallets
          </CardDescription>
        </CardHeader>
        <CardContent>
          {loading ? (
            <div className="flex items-center justify-center py-12">
              <Loader2 className="w-8 h-8 animate-spin text-primary" />
            </div>
          ) : wallets.length === 0 ? (
            <div className="text-center py-12">
              <Wallet className="w-12 h-12 mx-auto text-muted-foreground mb-4" />
              <p className="text-muted-foreground">No treasury wallets found</p>
              <p className="text-sm text-muted-foreground mt-1">
                Create your first wallet to get started
              </p>
            </div>
          ) : (
            <div className="rounded-md border">
              <Table>
                <TableHeader>
                  <TableRow>
                    <TableHead>Wallet ID</TableHead>
                    <TableHead>Wallet Address</TableHead>
                    <TableHead>Chain</TableHead>
                    <TableHead>Currency</TableHead>
                    <TableHead>Status</TableHead>
                    <TableHead>Created</TableHead>
                    <TableHead className="text-right">Actions</TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  {wallets.map((wallet) => (
                    <TableRow key={wallet.id}>
                      <TableCell className="font-mono text-sm">
                        <div className="flex items-center gap-2">
                          <span className="truncate max-w-[150px]" title={wallet.wallet_id}>
                            {wallet.wallet_id}
                          </span>
                          <Button
                            variant="ghost"
                            size="sm"
                            onClick={() => copyToClipboard(wallet.wallet_id, 'Wallet ID')}
                            className="h-6 w-6 p-0"
                          >
                            <Copy className="w-3 h-3" />
                          </Button>
                        </div>
                      </TableCell>
                      <TableCell className="font-mono text-sm">
                        <div className="flex items-center gap-2">
                          <span className="truncate max-w-[120px]" title={wallet.wallet_address}>
                            {wallet.wallet_address.slice(0, 6)}...{wallet.wallet_address.slice(-4)}
                          </span>
                          <Button
                            variant="ghost"
                            size="sm"
                            onClick={() => copyToClipboard(wallet.wallet_address, 'Address')}
                            className="h-6 w-6 p-0"
                          >
                            <Copy className="w-3 h-3" />
                          </Button>
                          <Button
                            variant="ghost"
                            size="sm"
                            onClick={() => window.open(getChainExplorerUrl(wallet.chain, wallet.wallet_address), '_blank')}
                            className="h-6 w-6 p-0"
                          >
                            <ExternalLink className="w-3 h-3" />
                          </Button>
                        </div>
                      </TableCell>
                      <TableCell>
                        <Badge className={getChainBadgeColor(wallet.chain)}>
                          {getChainName(wallet.chain)}
                        </Badge>
                      </TableCell>
                      <TableCell>
                        {wallet.currency ? (
                          <Badge variant="outline">{wallet.currency}</Badge>
                        ) : (
                          <span className="text-muted-foreground text-sm">—</span>
                        )}
                      </TableCell>
                      <TableCell>
                        <Badge className={getStatusBadgeColor(wallet.status)}>
                          {wallet.status}
                        </Badge>
                      </TableCell>
                      <TableCell className="text-sm text-muted-foreground">
                        {new Date(wallet.created_at).toLocaleDateString('en-US', {
                          month: 'short',
                          day: 'numeric',
                          year: 'numeric',
                        })}
                      </TableCell>
                      <TableCell className="text-right">
                        <Button
                          variant="ghost"
                          size="sm"
                          onClick={() => {
                            // TODO: Implement view details modal
                            toast.info('View details coming soon!');
                          }}
                        >
                          <Eye className="w-4 h-4" />
                        </Button>
                      </TableCell>
                    </TableRow>
                  ))}
                </TableBody>
              </Table>
            </div>
          )}
        </CardContent>
      </Card>

      {/* Helpful Information */}
      <Card>
        <CardHeader>
          <CardTitle className="text-sm">💡 Setup Instructions</CardTitle>
        </CardHeader>
        <CardContent className="space-y-3 text-sm">
          <div>
            <p className="font-semibold mb-2">Before you can create wallets:</p>
            <ol className="list-decimal list-inside space-y-1 text-muted-foreground ml-2">
              <li>Run the database migration: <code className="text-xs bg-slate-100 px-1 py-0.5 rounded">supabase/migrations/025_create_treasury_wallets_table.sql</code></li>
              <li>Set <code className="text-xs bg-slate-100 px-1 py-0.5 rounded">OPENFORT_API_KEY</code> in Supabase secrets</li>
              <li>Deploy the Edge Function: <code className="text-xs bg-slate-100 px-1 py-0.5 rounded">supabase functions deploy server</code></li>
            </ol>
          </div>
          <div>
            <p className="font-semibold mb-2">About Treasury Wallets:</p>
            <ul className="space-y-1 text-muted-foreground ml-2">
              <li>• Treasury wallets are created via Openfort API and stored in your database</li>
              <li>• Use these wallet IDs in your payment flows and settlement processes</li>
              <li>• You can view wallet balances and transactions on the blockchain explorer</li>
            </ul>
          </div>
        </CardContent>
      </Card>
    </div>
  );
}